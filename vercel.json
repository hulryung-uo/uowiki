{
  "headers": [
    {
      "source": "/wiki/recent.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.uotavern.com" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path((?!wiki).*)",
      "destination": "https://www.uotavern.com/wiki/:path",
      "permanent": true
    }
  ]
}
